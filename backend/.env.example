PORT=4000
NODE_ENV=development

# Base de datos MySQL/MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=fundacion_user
DB_PASSWORD=cambia_esta_clave
DB_NAME=fundacion_db

# Seguridad
JWT_SECRET=cambia_esta_clave_secreta_por_una_muy_larga_y_aleatoria
